	<parameter name="report_date" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT DISTINCT stock.id,
	product.id,
	product.name,
	unit.name,
	stock.quantity,
	stock_update_item.buying_price,
	stock.selling_price
FROM stock
	INNER JOIN stock_update_item ON 
	 stock_update_item.stock_id = stock.id 
	INNER JOIN product ON 
	 stock.product_id = product.id 
	INNER JOIN brand_has_series ON 
	 product.brand_has_series_id = brand_has_series.id 
	INNER JOIN unit ON 
	 product.unit_id = unit.id 
ORDER BY product.name ASC]]>
	</queryString>
